<svg viewBox="0 0 500 160" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <!-- 定义阴影和高光，制造新拟态效果 -->
    <filter id="neumorphism" x="-0.05" y="-0.05" width="1.1" height="1.1">
      <feDropShadow dx="3" dy="3" stdDeviation="4" flood-opacity="0.2" flood-color="#A0B0C0"/>
      <feDropShadow dx="-3" dy="-3" stdDeviation="4" flood-opacity="0.2" flood-color="#FFFFFF"/>
    </filter>
  </defs>
  <!-- 主图形区域：一个带有新拟态质感的圆形容器 -->
  <g transform="translate(50, 25)">
    <rect x="10" y="10" width="100" height="100" rx="30" fill="#EFF3F6" filter="url(#neumorphism)"/>
    <!-- 内部的波浪抽象图形，同样带有轻微凹凸感 -->
    <path d="M35,70 Q45,45 65,45 Q85,45 85,70" stroke="#4A708B" stroke-width="5" fill="none" stroke-linecap="round"/>
    <circle cx="60" cy="58" r="6" fill="#4A708B" />
    <!-- 代表“颜”的小色块 -->
    <circle cx="75" cy="65" r="5" fill="#E78A64" />
  </g>
  <!-- 文字也融入新拟态风格 -->
  <text x="180" y="80" font-size="60" font-family="'Segoe UI', Arial, sans-serif" font-weight="400" fill="#4A6A8A" filter="url(#neumorphism)">浪颜</text>
  <text x="300" y="120" font-size="30" font-family="'Segoe UI', Arial, sans-serif" font-weight="300" fill="#7F8C8D">blog</text>
</svg>