#!/bin/bash

# ==================================================
# 一键提交并推送脚本
# 提交信息固定为 "1"
# 使用前请确保已配置 git 用户名/邮箱 和 远程仓库
# ==================================================

echo "🚀 开始一键提交并推送..."

# 1. 检查是否在 Git 仓库中
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "❌ 错误：当前目录不是 Git 仓库！请在项目根目录下运行此脚本。"
    exit 1
fi

# 2. 获取当前分支名
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
if [ -z "$BRANCH" ]; then
    echo "❌ 错误：无法获取当前分支名（可能处于分离 HEAD 状态）"
    exit 1
fi
echo "📌 当前分支：$BRANCH"

# 3. 检查是否有未提交的更改
if git diff --quiet HEAD -- ; then
    if git diff --quiet --cached HEAD -- ; then
        echo "ℹ️ 无任何更改，无需提交。"
        exit 0
    fi
fi

# 4. 添加所有更改（包括新文件）
echo "➕ 正在添加所有文件..."
git add .

# 5. 提交更改（信息为 "1"）
echo "📝 正在提交：git commit -m \"1\""
git commit -m "1"

# 6. 检查远程是否存在
REMOTE="origin"
if ! git remote get-url $REMOTE > /dev/null 2>&1; then
    echo "❌ 错误：远程仓库 '$REMOTE' 不存在！请先设置远程仓库："
    echo "   git remote add origin <your-repo-url>"
    exit 1
fi

# 7. 推送代码
echo "📤 正在推送至远程分支 $REMOTE/$BRANCH..."
if git push -u $REMOTE $BRANCH 2>/dev/null; then
    echo "✅ 提交并推送成功！"
else
    echo "❌ 推送失败！请检查网络或远程权限。"
    echo "   可能需要手动推送：git push $REMOTE $BRANCH"
    exit 1
fi

echo "🎉 恭喜！一键提交推送完成！"
